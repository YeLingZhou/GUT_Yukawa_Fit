         "V2", ",", "V1", ",", "mv", ",", "Vckm", ",", "Vpmns", ",", "qt12", 
         ",", "qt13", ",", "qt23", ",", "qdcp", ",", "vt12", ",", "vt13", ",",
          "vt23", ",", "k", ",", "v\[Theta]12", ",", "v\[Theta]13", ",", 
         "v\[Theta]23", ",", "v\[Theta]12er", ",", "v\[Theta]13er", ",", 
         "v\[Theta]23er", ",", "\[CapitalDelta]ms21", ",", 
         "\[CapitalDelta]ms23", ",", "\[CapitalDelta]ms21er", ",", 
         "\[CapitalDelta]ms23er", ",", "vdcp", ",", "\[Rho]", ",", "\[Sigma]",
          ",", "MN", ",", "mcos", ",", "me", ",", "mee", ",", "chit", ",", 
         "dx", ",", "sx", ",", "ax", ",", "UV"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"v\[Theta]12", "=", 
         RowBox[{"\[Nu]para", "[", "\"\<v\[Theta]12\>\"", "]"}]}], ";", 
        RowBox[{"v\[Theta]13", "=", 
         RowBox[{"\[Nu]para", "[", "\"\<v\[Theta]13\>\"", "]"}]}], ";", 
        RowBox[{"v\[Theta]23", "=", 
         RowBox[{"\[Nu]para", "[", "\"\<v\[Theta]23\>\"", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"v\[Theta]12er", "=", 
         RowBox[{"\[Nu]para", "[", "\"\<v\[Theta]12er\>\"", "]"}]}], ";", 
        RowBox[{"v\[Theta]13er", "=", 
         RowBox[{"\[Nu]para", "[", "\"\<v\[Theta]13er\>\"", "]"}]}], ";", 
        RowBox[{"v\[Theta]23er", "=", 
         RowBox[{"\[Nu]para", "[", "\"\<v\[Theta]23er\>\"", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"\[CapitalDelta]ms21", "=", 
         RowBox[{"\[Nu]para", "[", "\"\<\[CapitalDelta]ms21\>\"", "]"}]}], 
        ";", 
        RowBox[{"\[CapitalDelta]ms23", "=", 
         RowBox[{"\[Nu]para", "[", "\"\<\[CapitalDelta]ms23\>\"", "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"\[CapitalDelta]ms21er", "=", 
         RowBox[{"\[Nu]para", "[", "\"\<\[CapitalDelta]ms21er\>\"", "]"}]}], 
        ";", 
        RowBox[{"\[CapitalDelta]ms23er", "=", 
         RowBox[{"\[Nu]para", "[", "\"\<\[CapitalDelta]ms23er\>\"", "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"sx", "=", 
         RowBox[{"(", GridBox[{
            {"s11", "s12", "s13"},
            {"s12", "s22", "s23"},
            {"s13", "s23", "s33"}
           }], ")"}]}], ";", 
        RowBox[{"dx", "=", 
         RowBox[{"(", GridBox[{
            {"d11", "0", "0"},
            {"0", "d22", "0"},
            {"0", "0", "d33"}
           }], ")"}]}], ";", 
        RowBox[{"ax", "=", 
         RowBox[{"(", GridBox[{
            {"0", "a12", "a13"},
            {
             RowBox[{"-", "a12"}], "0", "a23"},
            {
             RowBox[{"-", "a13"}], 
             RowBox[{"-", "a23"}], "0"}
           }], ")"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"yu", "=", 
         RowBox[{
          RowBox[{
           SuperscriptBox["E", 
            RowBox[{"I", "*", "\[Alpha]"}]], "sx"}], " ", "+", 
          "                         ", "dx", "+", 
          RowBox[{
           SuperscriptBox["E", 
            RowBox[{"I", "*", "\[Lambda]"}]], "ax"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"yd", "=", 
         RowBox[{
          RowBox[{
           SuperscriptBox["E", 
            RowBox[{
             RowBox[{"-", "I"}], "*", "\[Alpha]"}]], "sx"}], "+", "     ", 
          RowBox[{"r1", "*", 
           SuperscriptBox["E", 
            RowBox[{"I", "*", "\[Omega]"}]], "*", "dx"}], "+", 
          RowBox[{
           SuperscriptBox["E", 
            RowBox[{
             RowBox[{"-", "I"}], "*", "\[Lambda]"}]], "ax"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ye", "=", 
         RowBox[{
          RowBox[{
           SuperscriptBox["E", 
            RowBox[{
             RowBox[{"-", "I"}], "*", "\[Alpha]"}]], "sx"}], "-", "  ", 
          RowBox[{"3", "r1", "*", 
           SuperscriptBox["E", 
            RowBox[{"I", "*", "\[Omega]"}]], "*", "dx"}], "+", 
          RowBox[{"r4", "*", 
           SuperscriptBox["E", 
            RowBox[{
             RowBox[{"-", "I"}], "*", "\[Gamma]"}]], "*", "ax"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"yv", "=", 
         RowBox[{
          RowBox[{
           SuperscriptBox["E", 
            RowBox[{"I", "*", "\[Alpha]"}]], "sx"}], " ", "-", 
          "                       ", 
          RowBox[{"3", "dx"}], "+", 
          RowBox[{"r4", "*", 
           SuperscriptBox["E", 
            RowBox[{"I", "*", "\[Gamma]"}]], "ax"}]}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"mv", "=", 
         RowBox[{
          RowBox[{"-", "m0"}], "*", 
          RowBox[{"yv", ".", 
           RowBox[{"(", GridBox[{
              {
               RowBox[{"1", "/", "d11"}], "0", "0"},
              {"0", 
               RowBox[{"1", "/", "d22"}], "0"},
              {"0", "0", 
               RowBox[{"1", "/", "d33"}]}
             }], ")"}], ".", 
           SuperscriptBox["yv", "\[Transpose]"]}]}]}], ";", 
        RowBox[{"(*", "eV", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"MN", "=", 
         RowBox[{
          RowBox[{"dx", "/", "m0"}], "*", 
          SuperscriptBox["174", "2"], "*", 
          SuperscriptBox["10", "9"]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"tprs", ",", "cprs", ",", "uprs"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"U3", ",", "U2", ",", "U1"}], "}"}]}], "}"}], "=", 
         RowBox[{
          RowBox[{"Eigensystem", "[", 
           RowBox[{"yu", ".", 
            SuperscriptBox["yu", "\[ConjugateTranspose]"]}], "]"}], "//", 
          "N"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"bprs", ",", "sprs", ",", "dprs"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"D3", ",", "D2", ",", "D1"}], "}"}]}], "}"}], "=", 
         RowBox[{
          RowBox[{"Eigensystem", "[", 
           RowBox[{"yd", ".", 
            SuperscriptBox["yd", "\[ConjugateTranspose]"]}], "]"}], "//", 
          "N"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"\[Tau]prs", ",", "\[Mu]prs", ",", "eprs"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"E3", ",", "E2", ",", "E1"}], "}"}]}], "}"}], "=", 
         RowBox[{
          RowBox[{"Eigensystem", "[", 
           RowBox[{"ye", ".", 
            SuperscriptBox["ye", "\[ConjugateTranspose]"]}], "]"}], "//", 
          "N"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"m2prs", ",", "m1prs", ",", "m3prs"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"V2", ",", "V1", ",", "V3"}], "}"}]}], "}"}], "=", 
         RowBox[{
          RowBox[{"Eigensystem", "[", 
           RowBox[{"mv", ".", 
            SuperscriptBox["mv", "\[ConjugateTranspose]"]}], "]"}], "//", 
          "N"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"UV", "=", 
         RowBox[{"Transpose", "[", 
          RowBox[{"Normalize", "/@", 
           RowBox[{"{", 
            RowBox[{"V2", ",", "V1", ",", "V3"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"UV", "=", 
         RowBox[{"UV", ".", 
          RowBox[{"MatrixExp", "[", 
           RowBox[{"I", "*", 
            RowBox[{
             RowBox[{"DiagonalMatrix", "[", 
              RowBox[{"Arg", "[", 
               RowBox[{"Diagonal", "[", 
                RowBox[{
                 SuperscriptBox["UV", "\[ConjugateTranspose]"], ".", "mv", 
                 ".", 
                 SuperscriptBox["UV", "\[Conjugate]"]}], "]"}], "]"}], "]"}], 
             "/", "2"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
