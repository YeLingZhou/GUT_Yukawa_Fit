Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"M2$Chi2", "[", 
      RowBox[{
      "s11_", ",", "s12_", ",", "s13_", ",", "s22_", ",", "s23_", ",", "s33_",
        ",", "d11_", ",", "d22_", ",", "d33_", ",", "a12_", ",", "a13_", ",", 
       "a23_", ",", "\[Alpha]_", ",", "\[Lambda]_", ",", "r1_", ",", "r4_", 
       ",", "\[Omega]_", ",", "\[Gamma]_", ",", "m0_", ",", "\[Nu]para_"}], 
      "]"}], ":=", "\[IndentingNewLine]", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "yu", ",", "yd", ",", "ye", ",", "yv", ",", "tprs", ",", "cprs", ",", 
         "uprs", ",", "U3", ",", "U2", ",", "U1", ",", "bprs", ",", "sprs", 
         ",", "dprs", ",", "D3", ",", "D2", ",", "D1", ",", "\[Tau]prs", ",", 
